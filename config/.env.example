# Destiny OS Configuration
# Copy to .env and fill in your values

# Vault path (defaults to ~/DestinyOS/vault)
# DESTINY_VAULT_PATH=~/DestinyOS/vault

# Provider configuration
# DESTINY_PROVIDER=claude-code  # claude-code, openai, or local
# DESTINY_MAX_TOKENS=8192
# DESTINY_TEMPERATURE=0.7

# Google Workspace (OAuth device flow)
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-client-secret

# Google Workspace (Service Account for Enterprise)
# GOOGLE_SERVICE_ACCOUNT_PATH=~/DestinyOS/credentials/google-service-account.json

# OpenAI (alternative provider)
# OPENAI_API_KEY=sk-...

# Config file path (defaults to ~/DestinyOS/config.json)
# DESTINY_CONFIG_PATH=~/DestinyOS/config.json
