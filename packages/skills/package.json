    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@destiny-os/runtime": "*",
    "@destiny-os/shared": "*"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  }
}
